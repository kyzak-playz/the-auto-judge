# Default: treat all text files as text and normalize to LF
* text=auto eol=lf

# Explicit rules for common source files
*.py     text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.html   text eol=lf
*.css    text eol=lf

# Git config files
.gitattributes text eol=lf
.gitignore     text eol=lf

# Mark binary files so Git never tries to change line endings
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.tar    binary
*.gz     binary

# SVG files are text but should use LF line endings
*.svg text eol=lf

# Draw.io diagrams are binary (don’t touch line endings)
*.drawio binary

# Windows executables / DLLs
*.exe    binary
*.dll    binary

# OS-script files (e.g., shell scripts) should be treated as text with LF line endings
*.sh     text eol=lf
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf