# Backend environment template
APP_ENV=development
APP_NAME=The Auto Judge Backend

# Supabase Postgres connection string 
DATABASE_URI=postgresql://postgres:<password>@<host>:5432/postgres 

# Supabase project and key boundaries (backend-only secrets)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET=sb_secret_<service_role_or_secret_key>
SUPABASE_JWT_SIGNING_KEY=<supabase_jwt_signing_key>

# Optional in backend (used only if token checks need it)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<publishable_key>
